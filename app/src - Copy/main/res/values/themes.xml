<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.RecipeBook" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_700</item>
        <item name="colorPrimaryVariant">@color/color_toolbar_background</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orang_ligt</item>
        <item name="colorSecondaryVariant">@color/primarycolor</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/color_status_bar</item>
    </style>


    <style name="Theme.RecipeBook.SearchView" parent="Widget.AppCompat.SearchView">
        <item name="android:textColorHint">@color/color_hint_gray</item>
        <item name="android:textColor">@color/color_text_dark</item>
        <item name="queryBackground">@android:color/transparent</item>
        <item name="searchIcon">@drawable/ic_search</item>
        <item name="closeIcon">@drawable/ic_close</item>
        <item name="android:textCursorDrawable">@null</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="TextAppearance.App.TabElegant" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>
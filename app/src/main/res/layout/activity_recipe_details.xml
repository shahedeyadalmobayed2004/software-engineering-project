<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_cream_background"
    android:fillViewport="true"
    tools:context=".RecipeDetailsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="40dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="12dp"
            app:strokeColor="@color/burnt_orange_darker"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <ImageView
                    android:id="@+id/recipeImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Recipe Image"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_image_placeholder"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/favoriteButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Favorite"
                        app:backgroundTint="@color/white"
                        app:fabSize="mini"
                        app:srcCompat="@drawable/ic_favorite"
                        app:tint="@color/warm_gray_text" />

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/shareButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="Share"
                        app:backgroundTint="@color/white"
                        app:fabSize="mini"
                        app:srcCompat="@drawable/ic_share"
                        app:tint="@color/warm_gray_text" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/favoriteBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Favorite Button"
                    android:elevation="10dp"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/btn_star_big_off"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/videoLinkText"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_youtube"
                    app:iconGravity="textStart"
                    app:iconTint="@color/youtube_red"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/lora"
            android:letterSpacing="0.01"
            android:lineSpacingExtra="8dp"
            android:textColor="@color/soft_black_text"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="Creamy Tomato Basil Pasta with Chicken" />

        <TextView
            android:id="@+id/categoryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/crimson"
            android:textColor="@color/warm_gray_text"
            android:textSize="20sp"
            tools:text="Italian Cuisine" />


        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/card_background_cream"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeColor="#A0A0A0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/lora"
                    android:letterSpacing="0.01"
                    android:text="Ingredients:"
                    android:textColor="@color/soft_black_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/ingredientsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fadingEdge="vertical"
                    android:lineSpacingExtra="9dp"
                    android:maxLines="7"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="vertical"
                    android:textColor="@color/warm_gray_text"
                    android:textSize="18sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="@color/card_background_cream"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeColor="#A0A0A0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/lora"
                    android:letterSpacing="0.01"
                    android:text="Steps:"
                    android:textColor="@color/soft_black_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/stepsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="9dp"
                    android:maxLines="7"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="vertical"
                    android:textColor="@color/warm_gray_text"
                    android:textSize="18sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <Button
            android:id="@+id/btnShoppingList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Shopping List"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:id="@+id/editDeleteLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="Edit Recipe"
                android:textColor="@color/primary_app_orange"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="32dp"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/primary_app_orange"
                app:strokeColor="@color/primary_app_orange"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="Delete Recipe"
                android:textColor="@color/delete_red"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="32dp"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/delete_red"
                app:strokeColor="@color/delete_red"
                app:strokeWidth="2dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>